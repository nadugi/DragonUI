				</Texture>
				<Texture name="$parentBRTop" file="Interface\MerchantFrame\UI-Merchant-BotRight">
					<Size x="64" y="128"/>
					<Anchors><Anchor point="BOTTOMRIGHT"><Offset x="0" y="128"/></Anchor></Anchors>
					<TexCoords left="0.5" right="1" top="0" bottom="0.5"/>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentCloseButton" inherits="UIPanelCloseButton">
				<Anchors><Anchor point="TOPRIGHT"><Offset x="-29" y="-8"/></Anchor></Anchors>
			</Button>
			<Button name="$parentIconButton" inherits="DragonUI_CombuctorIconButtonTemplate"/>
			<Button name="$parentTitle" inherits="DragonUI_CombuctorDragFrameTemplate"/>
			<EditBox name="$parentSearch" inherits="DragonUI_CombuctorSearchBoxTemplate"/>
			<Button name="$parentReset" inherits="DragonUI_CombuctorResetButtonTemplate">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentSearch" relativePoint="RIGHT">
						<Offset x="-2" y="-2"/>
					</Anchor>
				</Anchors>
			</Button>
			<Button name="$parentBagToggle" inherits="DragonUI_CombuctorBagToggleTemplate">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentReset" relativePoint="RIGHT"/>
				</Anchors>
			</Button>
			<Button name="$parentResize">
				<Size x="16" y="16"/>
				<Anchors>
					<Anchor point="BOTTOMRIGHT"><Offset x="-40" y="66"/></Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>
						self:SetFrameLevel(self:GetFrameLevel() + 4)
						self:GetNormalTexture():SetVertexColor(1, 0.82, 0)
					</OnLoad>
					<OnMouseDown>
						self:GetParent():StartSizing()
					</OnMouseDown>
					<OnMouseUp>
						self:GetParent():StopMovingOrSizing()
					</OnMouseUp>
				</Scripts>
				<NormalTexture file="Interface\ChatFrame\UI-ChatIM-SizeGrabber-Up" setAllPoints="true"/>
				<PushedTexture file="Interface\ChatFrame\UI-ChatIM-SizeGrabber-Down" setAllPoints="true"/>
				<HighlightTexture file="Interface\ChatFrame\UI-ChatIM-SizeGrabber-Up" alphaMode="ADD" setAllPoints="true"/>
			</Button>
		</Frames>
		<Scripts>
			<OnLoad>
				self:SetMinResize(self:GetWidth(), self:GetHeight())
			</OnLoad>
			<OnSizeChanged>
				self:OnSizeChanged()
			</OnSizeChanged>
		</Scripts>
	</Frame>
</Ui>
