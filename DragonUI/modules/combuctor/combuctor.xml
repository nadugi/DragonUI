					<Anchors><Anchor point="TOPRIGHT"/></Anchors>
					<TexCoords left="0.5" right="1" top="0" bottom="0.5"/>
				</Texture>
				<Texture name="$parentTRLeft" file="Interface\MerchantFrame\UI-Merchant-TopRight">
					<Size x="64" y="128"/>
